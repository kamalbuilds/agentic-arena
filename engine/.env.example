# Base RPC
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532

# Operator wallet (game engine)
OPERATOR_PRIVATE_KEY=0x_your_private_key_here

# Contract addresses (fill after deployment)
GAME_CONTRACT_ADDRESS=
BETTING_CONTRACT_ADDRESS=
LEADERBOARD_CONTRACT_ADDRESS=

# Moltbook API
MOLTBOOK_API_URL=https://moltbook.com/api
MOLTBOOK_API_KEY=moltbook_your_api_key_here
MOLTBOOK_SUBMOLT=m/amongclaws

# $CLAW Token (Base)
CLAW_TOKEN_ADDRESS=

# PostgreSQL (Railway addon provides this automatically)
DATABASE_URL=

# Server
PORT=3001
WS_PORT=3002

# Game Config
DEFAULT_STAKE=500000000000000000
MIN_PLAYERS=5
MAX_PLAYERS=8
DISCUSSION_DURATION=180
VOTING_DURATION=60
MAX_ROUNDS=5
IMPOSTOR_COUNT=1

# Coinbase AgentKit (CDP Server Wallets for agents)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ERC-8004 Registries (on-chain agent identity)
# Canonical CREATE2 addresses are auto-resolved by chain ID if left empty.
# Base Mainnet: Identity=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432 Reputation=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# Base Sepolia: Identity=0x8004A818BFB912233c491871b3d84c89A494BD9e Reputation=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_IDENTITY_REGISTRY=
ERC8004_REPUTATION_REGISTRY=
# ValidationRegistry is not yet in the canonical deployment, set manually if deployed
ERC8004_VALIDATION_REGISTRY=

# Uniswap Trading API (token swaps on Base)
# Get API key at https://developers.uniswap.org/
UNISWAP_API_KEY=

# Locus Payment Infrastructure (USDC payments for agents)
# Register via POST /api/locus/register or at https://beta.paywithlocus.com
LOCUS_API_KEY=
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api
GAME_TREASURY_ADDRESS=

# Anthropic Claude (autonomous agent LLM decisions)
ANTHROPIC_API_KEY=

# Gemini AI (image generation + theme generation)
GEMINI_API_KEY=

# Autonomous Agent Config
AGENT_COUNT=6
GAME_SERVER_URL=http://localhost:3001